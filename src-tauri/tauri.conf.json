{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "enowxwatcher",
  "version": "0.1.0",
  "identifier": "com.enowdev.enowxwatcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "enowxwatcher",
        "width": 1000,
        "height": 680,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "visible": true,
        "skipTaskbar": false,
        "center": true
      },
      {
        "label": "tray",
        "url": "index.html?view=tray",
        "width": 340,
        "height": 460,
        "resizable": false,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "enowxwatcher"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}